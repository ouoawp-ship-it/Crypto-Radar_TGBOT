# P3.1 Base collector remains disabled and Telegram dry-run by default.
ONCHAIN_ENABLE=false
ONCHAIN_REAL_SEND=false

ONCHAIN_DATA_DIR=data/onchain
ONCHAIN_DB_FILE=onchain_flow.db
ONCHAIN_RUNTIME_STATUS_FILE=runtime_status.json
ONCHAIN_TG_PUSH_HISTORY_FILE=tg_push_history.json
ONCHAIN_TG_OUTBOX_FILE=tg_outbox.json
ONCHAIN_TG_TOPIC_ROUTES_FILE=tg_topic_routes.json
ONCHAIN_SIGNAL_EVENTS_FILE=signal_events.json
ONCHAIN_SIGNAL_EVENTS_DB_FILE=onchain_signals.db

ONCHAIN_CHAINS_FILE=config/onchain/chains.example.json
ONCHAIN_CEX_LABELS_FILE=config/onchain/cex_addresses.example.csv

ONCHAIN_BASE_ENABLE=false
ONCHAIN_BASE_CHAIN_ID=8453
ONCHAIN_BASE_HTTP_RPC_URL=
ONCHAIN_BASE_WSS_RPC_URL=
ONCHAIN_BASE_CONFIRMATION_DEPTH=20
ONCHAIN_BASE_BOOTSTRAP_LOOKBACK_BLOCKS=300
ONCHAIN_BASE_REORG_LOOKBACK_BLOCKS=64

ONCHAIN_RPC_TIMEOUT_SEC=10
ONCHAIN_RPC_RETRY=3
ONCHAIN_RPC_BACKOFF_SEC=1
ONCHAIN_RPC_MAX_BLOCK_RANGE=1000
ONCHAIN_RPC_MIN_BLOCK_RANGE=1
ONCHAIN_RPC_TOPIC_ADDRESS_BATCH=50
ONCHAIN_RPC_POLL_SEC=5
ONCHAIN_RPC_RATE_LIMIT_PER_SECOND=20
ONCHAIN_RPC_ADAPTIVE_MAX_REQUESTS=64
ONCHAIN_RPC_ADAPTIVE_MAX_DEPTH=12

ONCHAIN_WSS_RECONNECT_SEC=5
ONCHAIN_WSS_IDLE_TIMEOUT_SEC=30
ONCHAIN_WSS_QUEUE_MAX=100

ONCHAIN_PRICE_ENABLE=false
ONCHAIN_PRICE_PROVIDER=none
ONCHAIN_PRICE_MAX_AGE_SEC=300
ONCHAIN_PRICE_BATCH_SIZE=50
ONCHAIN_PRICE_RATE_LIMIT_PER_MINUTE=30
ONCHAIN_COINGECKO_API_BASE_URL=https://pro-api.coingecko.com/api/v3
ONCHAIN_COINGECKO_API_KEY=

ONCHAIN_NET_DOMINANCE_MIN=0.60
ONCHAIN_ROLLING_EVALUATION_BUCKET_SEC=300

ONCHAIN_TG_HOURLY_LIMIT=6
ONCHAIN_ALERT_COOLDOWN_SEC=3600
ONCHAIN_ALERT_MAX_EVENT_AGE_SEC=1800
TG_ONCHAIN_FLOW_TOPIC_ID=

ONCHAIN_MIN_LABEL_CONFIDENCE=0.80
ONCHAIN_SINGLE_LARGE_FLOOR_USD=1000000
ONCHAIN_BATCH_15M_FLOOR_USD=2000000
ONCHAIN_CONTINUOUS_60M_FLOOR_USD=4000000
ONCHAIN_SINGLE_VOLUME_RATIO=0.001
ONCHAIN_BATCH_VOLUME_RATIO=0.002
ONCHAIN_CONTINUOUS_VOLUME_RATIO=0.004
ONCHAIN_BASELINE_MAD_MULTIPLIER=3
