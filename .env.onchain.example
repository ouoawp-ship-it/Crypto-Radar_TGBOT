# P3.0 is disabled and dry-run by default. Real RPC/WSS collection is deferred to P3.1.
ONCHAIN_ENABLE=false
ONCHAIN_REAL_SEND=false

ONCHAIN_DATA_DIR=data/onchain
ONCHAIN_DB_FILE=onchain_flow.db
ONCHAIN_RUNTIME_STATUS_FILE=runtime_status.json
ONCHAIN_TG_PUSH_HISTORY_FILE=tg_push_history.json
ONCHAIN_TG_OUTBOX_FILE=tg_outbox.json
ONCHAIN_TG_TOPIC_ROUTES_FILE=tg_topic_routes.json
ONCHAIN_SIGNAL_EVENTS_FILE=signal_events.json
ONCHAIN_SIGNAL_EVENTS_DB_FILE=onchain_signals.db

ONCHAIN_CHAINS_FILE=config/onchain/chains.example.json
ONCHAIN_CEX_LABELS_FILE=config/onchain/cex_addresses.example.csv

ONCHAIN_TG_HOURLY_LIMIT=6
ONCHAIN_ALERT_COOLDOWN_SEC=3600
TG_ONCHAIN_FLOW_TOPIC_ID=

ONCHAIN_MIN_LABEL_CONFIDENCE=0.80
ONCHAIN_SINGLE_LARGE_FLOOR_USD=1000000
ONCHAIN_BATCH_15M_FLOOR_USD=2000000
ONCHAIN_CONTINUOUS_60M_FLOOR_USD=4000000
ONCHAIN_SINGLE_VOLUME_RATIO=0.001
ONCHAIN_BATCH_VOLUME_RATIO=0.002
ONCHAIN_CONTINUOUS_VOLUME_RATIO=0.004
ONCHAIN_BASELINE_MAD_MULTIPLIER=3
