{
  "name": "paoxx-public-dashboard",
  "version": "1.91.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --hostname 127.0.0.1 --port 3000",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:functional": "playwright test --grep-invert \"paoxx workstation visual fixtures remain stable\"",
    "e2e:visual": "node ./scripts/run-visual.mjs",
    "visual:update": "playwright test --grep \"paoxx workstation visual fixtures remain stable\" --update-snapshots"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "geist": "^1.7.2",
    "next": "16.2.11",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "20.19.9",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  },
  "overrides": {
    "postcss": "8.5.10",
    "sharp": "0.35.3"
  }
}
