# Telegram
TG_BOT_TOKEN=
TG_CHAT_ID=
TG_TOPIC_ID=
TELEGRAM_USE_TOPIC=false
# Optional forum-topic routes. Empty value falls back to TG_TOPIC_ID.
TG_RADAR_SUMMARY_TOPIC_ID=
TG_LAUNCH_ALERT_TOPIC_ID=
TG_ANNOUNCEMENT_ALERT_TOPIC_ID=
TG_TEST_TOPIC_ID=
TG_FLOW_RADAR_TOPIC_ID=
TG_FUNDING_ALERT_TOPIC_ID=
TG_AUTO_CREATE_TOPICS=true
TG_TOPIC_ROUTES_FILE=tg_topic_routes.json
TG_TOPIC_INTRO_ENABLE=true
TG_TOPIC_INTRO_PIN=true

# Web console. Public route: https://paoxx.com/ ; admin route: https://paoxx.com/admin.
# Password mode is the default. Run `.venv/bin/python main.py admin-password set` to set credentials.
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_AUTH_MODE=password
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD_HASH=
WEB_SESSION_SECRET=
WEB_SESSION_TTL_SEC=86400
WEB_AUTH_COOKIE_NAME=paopao_admin_session
WEB_AUTH_MAX_FAILURES=5
WEB_AUTH_LOCKOUT_SEC=600
WEB_AUTH_FAILURE_WINDOW_SEC=900
WEB_AUTH_AUDIT_LIMIT=500
WEB_SESSION_REFRESH_THRESHOLD_RATIO=0.5
PAOXX_PUBLIC_BASE_URL=https://paoxx.com
PUBLIC_API_RATE_LIMIT_PER_MINUTE=180
PUBLIC_API_HEAVY_RATE_LIMIT_PER_MINUTE=30
# Only trust X-Forwarded-For when the direct peer is one of these local proxies.
PUBLIC_API_TRUSTED_PROXY_IPS=127.0.0.1,::1
# V2 cockpit rollout: enabled | preview | disabled. Rebuild the frontend after
# changing this value. Legacy signal APIs and Telegram Bot stay available.
PAOXX_COCKPIT_V2_MODE=enabled
NEWS_EVENTS_DB_FILE=news_events.db
AGENT_INSIGHTS_DB_FILE=agent_insights.db
NEWS_EVENTS_RETENTION_DAYS=90
NEWS_EVENTS_LIMIT=5000
# Legacy token mode only. Use WEB_AUTH_MODE=token for emergency rollback.
WEB_ADMIN_TOKEN=

# AI assistant bot. Optional and separate from the radar push bot.
AI_ASSISTANT_ENABLE=false
AI_BOT_TOKEN=
AI_BOT_USERNAME=
AI_ADMIN_USER_IDS=
# If enabled, group messages are handled only when users @mention the bot or reply to the bot.
AI_ALLOW_GROUP_CHAT=false
# Required for group usage when AI_ALLOW_GROUP_CHAT=true. Comma separated chat IDs or usernames.
AI_ALLOWED_CHAT_IDS=
AI_PRICE_ALERTS_ENABLE=true
AI_PRICE_ALERTS_DB_FILE=price_alerts.db
AI_DEFAULT_CHAT_ID=
AI_ALERT_CHECK_INTERVAL_SEC=30
AI_POLL_TIMEOUT_SEC=20
AI_PROVIDER_ENABLE=false
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-pro
AI_REQUEST_TIMEOUT_SEC=90
AI_PROMPTS_FILE=ai_prompts.json
SIGNAL_EVENTS_FILE=signal_events.json
SIGNAL_EVENTS_DB_FILE=signals.db
SIGNAL_EVENTS_LIMIT=5000
SIGNAL_EVENTS_RETENTION_DAYS=60
MARKET_SNAPSHOTS_DB_FILE=market_snapshots.db
MARKET_SNAPSHOT_INTERVAL_SEC=300
MARKET_SNAPSHOT_RETENTION_DAYS=30
MARKET_SNAPSHOT_LIMIT=160
MARKET_SNAPSHOT_OI_LIMIT=80
MARKET_SNAPSHOT_WORKERS=8
MARKET_FLOW_FACT_INTERVAL_SEC=900
MARKET_FLOW_FACT_LIMIT=40
MARKET_READINESS_TARGET_DAYS=30
REALTIME_FEATURES_DB_FILE=realtime_features.db
REALTIME_MARKET_BUCKET_SEC=60
REALTIME_MARKET_GRACE_MS=2000
REALTIME_MARKET_FLUSH_INTERVAL_SEC=1
REALTIME_MARKET_RECONNECT_SEC=5
REALTIME_MARKET_CONNECT_TIMEOUT_SEC=15
REALTIME_MARKET_IDLE_TIMEOUT_SEC=30
REALTIME_MARKET_RETENTION_DAYS=7
REALTIME_MARKET_SYMBOL_LIMIT=80
REALTIME_MARKET_MIN_QUOTE_VOLUME=5000000
REALTIME_MARKET_SYMBOL_REFRESH_SEC=300
REALTIME_BYBIT_ENABLE=true
REALTIME_OKX_ENABLE=true

# HTTP / data source
BINANCE_FAPI_BASE_URL=https://fapi.binance.com
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com/ws
BYBIT_PUBLIC_REST_URL=https://api.bybit.com
BYBIT_LINEAR_WS_URL=wss://stream.bybit.com/v5/public/linear
OKX_PUBLIC_REST_URL=https://www.okx.com
OKX_PUBLIC_WS_URL=wss://ws.okx.com:8443/ws/v5/public
BINANCE_API_TIMEOUT_SEC=10
BINANCE_API_RETRY=2
BINANCE_API_BACKOFF_SEC=0.8
DATA_SOURCE_CACHE_ENABLE=true
DATA_SOURCE_CACHE_TTL_SEC=10
DATA_SOURCE_FUSE_SECONDS=900
EXCLUDED_BASE_ASSETS=XAU,XAG

# Request budgets
OI_HIST_REQUEST_BUDGET=80
KLINE_REQUEST_BUDGET=120
FUNDING_HISTORY_REQUEST_BUDGET=25

# Telegram safety
TG_PUSH_HISTORY_FILE=tg_push_history.json
RUNTIME_STATUS_FILE=runtime_status.json
TG_PUSH_SPLIT_LIMIT=3800
TG_PUSH_TIMEOUT_SEC=10
TG_PUSH_RETRY=2
TG_GLOBAL_HOURLY_LIMIT=20
TG_DEFAULT_COOLDOWN_SEC=21600
TG_PUSH_HISTORY_LIMIT=2000
TG_PUSH_HISTORY_RETENTION_DAYS=30

# Runtime cleanup
CLEANUP_ENABLE=true
CLEANUP_INTERVAL_SEC=3600
CLEANUP_STATE_FILE=cleanup_state.json
CLEANUP_CORRUPT_RETENTION_DAYS=7
CLEANUP_LOG_RETENTION_DAYS=14

# Money radar
# 0 means disabled in the new safe runner.
RADAR_SCAN_LIMIT=120
RADAR_MIN_QUOTE_VOLUME=5000000
RADAR_TOP_N=8
RADAR_SUMMARY_MIN_INTERVAL_SEC=21600
RADAR_SUMMARY_CLOSE_DELAY_SEC=300
RADAR_SUMMARY_MAX_DAILY_PUSH=4
RADAR_STATE_FILE=radar_state.json
FUNDING_SNAPSHOT_FILE=funding_snapshot.json

# Five-factor flow radar
FLOW_SCAN_LIMIT=12
FLOW_CANDIDATE_POOL=50
FLOW_TOP_N=8
FLOW_MIN_SCORE=50
FLOW_INTERVAL_SEC=3600
FLOW_CLOSE_DELAY_SEC=300

# Funding-rate alert radar
FUNDING_ALERT_ENABLE=true
FUNDING_ALERT_INTERVAL_SEC=180
FUNDING_ALERT_SCAN_LIMIT=120
FUNDING_SCAN_CONCURRENCY=8
FUNDING_REQUEST_TIMEOUT_SEC=8
FUNDING_MAX_SYMBOLS_PER_BATCH=120
FUNDING_ALERT_MIN_QUOTE_VOLUME=5000000
FUNDING_ALERT_EXCHANGES=BINANCE,OKX,BYBIT,BITGET,GATE
FUNDING_ALERT_HISTORY_LIMIT=4
FUNDING_ALERT_COOLDOWN_SEC=3600
FUNDING_ALERT_EXTREME_NEGATIVE_PCT=-0.5
FUNDING_ALERT_SUPER_NEGATIVE_PCT=-1.0
FUNDING_ALERT_EXTREME_POSITIVE_PCT=0.5
FUNDING_ALERT_MIN_EXCHANGE_COUNT=2
FUNDING_ALERT_DIVERGENCE_PCT=0.75
FUNDING_ALERT_REPLY_CHAIN_ENABLE=true
FUNDING_ALERT_DECAY_QUIET_SCANS=2
FUNDING_ALERT_END_QUIET_SCANS=5
FUNDING_ALERT_STATE_FILE=funding_alert_state.json

# Launch radar
# 0 means disabled in the new safe runner.
LAUNCH_SCAN_LIMIT=80
LAUNCH_MULTI_EXCHANGE_FUNDING_ENABLE=true
LAUNCH_FUNDING_EXCHANGES=BINANCE,OKX,BYBIT,BITGET,GATE
LAUNCH_FUNDING_HISTORY_LIMIT=4
LAUNCH_STATE_FILE=launch_state.json
LAUNCH_WATCHLIST_FILE=launch_watchlist.json
LAUNCH_WATCH_HISTORY_FILE=launch_watch_history.json
LAUNCH_WATCH_HISTORY_LIMIT=500
LAUNCH_MIN_SCORE_PUSH=60
LAUNCH_WATCH_SCORE=45
LAUNCH_PRIMED_SCORE=60
LAUNCH_BREAKOUT_SCORE=75
LAUNCH_LAUNCHED_SCORE=90
LAUNCH_CLOSE_DELAY_SEC=60
LAUNCH_STAGE_COOLDOWN_SEC=21600
LAUNCH_STATE_TTL_SEC=172800
LAUNCH_FAILED_TTL_SEC=86400

# Announcements
ANNOUNCEMENT_STATE_FILE=announcement_state.json
ANNOUNCEMENT_PAGE_SIZE=50
ANNOUNCEMENT_ONLY_TODAY=true
ANNOUNCEMENT_DEFAULT_TTL_DAYS=3

# Divergence state
OI_DIVERGENCE_STATE_FILE=oi_divergence_state.json
OI_DIVERGENCE_COOLDOWN_FILE=oi_divergence_cooldown.json
